# Copy this file to ".env" and edit the values, then run `docker compose up --build`.
# (If you use ./run.sh instead, it sets these for you from the path you pass.)

# Absolute path on your HOST to the Google Takeout mbox file.
#   macOS / Linux example:  /Users/you/Downloads/Takeout/Mail/All mail.mbox
#   Windows example:        C:\Users\you\Downloads\Takeout\Mail\All mail.mbox
MBOX_FILE=/path/to/your-mail.mbox

# Host port to expose the viewer on (the container always listens on 9000 internally).
# The viewer is published on 127.0.0.1 only — see the security note in the README.
PORT=9000

# Durable host folder for the offline image archive (created if missing).
# Optional; defaults to ./mbox-viewer-archive next to this repo.
ARCHIVE_HOST_DIR=./mbox-viewer-archive
