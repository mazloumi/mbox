# Copy this file to ".env" and edit the values, then run `docker compose up --build`.
# (If you use ./run.sh instead, it sets these for you from the path you pass.)

# Absolute path on your HOST to the Google Takeout mbox file.
#   macOS / Linux example:  /Users/you/Downloads/Takeout/Mail/All mail.mbox
#   Windows example:        C:\Users\you\Downloads\Takeout\Mail\All mail.mbox
MBOX_FILE=/path/to/your-mail.mbox

# Host port to expose the viewer on (the container always listens on 9000 internally).
# The viewer is published on 127.0.0.1 only — see the security note in the README.
PORT=9000

# Durable host folder for the offline image archive (created if missing).
# Optional; defaults to ./mbox-viewer-archive next to this repo.
ARCHIVE_HOST_DIR=./mbox-viewer-archive

# --- Optional: local semantic search (fully on-device; no API key, no egress) ---
# Set to 1 to build a local vector index and enable meaning-based search.
# First enable runs a one-time background build (CPU) and downloads a ~130 MB
# embedding model on first use.
SEMANTIC_SEARCH=

# --- Optional: AI assistant (chat). Requires an Anthropic API key. ---
# When enabled, ONLY retrieved email snippets are sent to Anthropic (never the whole
# mailbox, never the embeddings). Enabling this implies SEMANTIC_SEARCH.
ASSISTANT_ENABLED=
ANTHROPIC_API_KEY=
ASSISTANT_MODEL=claude-sonnet-4-6

# Embedding backend: "local" (in-container CPU, default) or "ollama" (host, GPU).
EMBED_BACKEND=local
# EMBED_MODEL=BAAI/bge-small-en-v1.5
# OLLAMA_URL=http://host.docker.internal:11434
